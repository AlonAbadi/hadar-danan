# ══════════════════════════════════════════════════════
# HADAR DANAN — ADMIN DASHBOARD API INTEGRATIONS
# ══════════════════════════════════════════════════════

# ─── Core (already configured) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RESEND_API_KEY=

# ─── Cardcom (Israeli payment) ─────────────────────────
CARDCOM_TERMINAL_NUMBER=
CARDCOM_API_NAME=
CARDCOM_API_PASSWORD=

# ─── Meta Ads API ──────────────────────────────────────
# Get from: https://developers.facebook.com/tools/explorer/
# Permissions needed: ads_read, ads_management
META_ADS_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# ─── Google Ads API ────────────────────────────────────
# Get from: https://ads.google.com/home/tools/manager-accounts/
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# ─── GA4 Data API ─────────────────────────────────────
# Get from: https://analytics.google.com/
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# ─── Calendly API ─────────────────────────────────────
# Get from: https://calendly.com/integrations/api_webhooks
CALENDLY_API_TOKEN=

# ─── Vimeo API ─────────────────────────────────────────
# Get from: https://developer.vimeo.com/apps
VIMEO_ACCESS_TOKEN=

# ─── WhatsApp Business API ─────────────────────────────
# Get from: https://developers.facebook.com/apps/
WHATSAPP_BUSINESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ─── Vercel ────────────────────────────────────────────
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=
