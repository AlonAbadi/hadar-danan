{
  "expo": {
    "name": "כוורת האות",
    "slug": "kaveret-haot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080C14",
    "splash": {
      "backgroundColor": "#080C14",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "online.beegood.kaveret",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "חדר השידור מצלם אותך במצלמה הקדמית כדי ליצור את הרילס שלך.",
        "NSMicrophoneUsageDescription": "המיקרופון מקליט את הקול שלך לרילס ולכתוביות.",
        "NSPhotoLibraryAddUsageDescription": "שמירת הרילס המוכן לתמונות שלך."
      }
    },
    "android": {
      "package": "online.beegood.kaveret",
      "permissions": ["CAMERA", "RECORD_AUDIO"]
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "חדר השידור מצלם אותך במצלמה הקדמית.", "microphonePermission": "המיקרופון מקליט את הקול שלך לרילס." }],
      "expo-media-library",
      "expo-sharing",
      "expo-video"
    ]
  }
}
